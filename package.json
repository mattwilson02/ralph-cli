{
  "name": "ralph-agent",
  "version": "0.1.0",
  "description": "Autonomous AI dev agent. Point it at your codebase and product spec — it builds, verifies, and ships.",
  "type": "module",
  "bin": {
    "ralph": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.3",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ai",
    "agent",
    "cli",
    "autonomous",
    "developer-tools",
    "claude",
    "llm",
    "ai-agent",
    "sprint",
    "code-generation"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mattwilson02/ralph-cli"
  },
  "homepage": "https://github.com/mattwilson02/ralph-cli",
  "license": "MIT"
}
